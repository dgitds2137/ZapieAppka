APP_NAME=ZapieApp API
APP_ENV=local

# SQLAlchemy URL for Azure SQL / SQL Server.
# Keep the real value only in .env locally or in Azure App Service App Settings.
MSSQL_CONN_STR="mssql+pyodbc://USER:PASSWORD@SERVER.database.windows.net:1433/DATABASE?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no&loginTimeout=1200"

JWT_SECRET_KEY=change-me-to-a-long-random-secret

# Native Flutter apps do not need CORS, but Flutter Web and browser tools do.
CORS_ALLOW_ORIGINS=
CORS_ALLOW_ORIGIN_REGEX="^https?://(localhost|127\.0\.0\.1)(:\d+)?$"
CORS_ALLOW_CREDENTIALS=true

# Set to true in Azure if the app should fail startup when DB schema init fails.
REQUIRE_DATABASE_ON_STARTUP=false
