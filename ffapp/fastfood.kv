#:import dp kivy.metrics.dp
#:import FitImage kivymd.uix.fitimage.fitimage.FitImage
#:import sp kivy.metrics.sp

ScreenManager:
    RegisterScreen:
    LoginScreen:
    DashboardScreen:
    DeliveryScreen:
    PositionScreen:
    CartScreen:
    OrderSummaryScreen:
    OrdersHistoryScreen:
    AddressScreen:


#:import dp kivy.metrics.dp
#:import FitImage kivymd.uix.fitimage.fitimage.FitImage

<ProductCard>:
    orientation: "vertical"
    size_hint: None, None
    size: dp(280), dp(300)
    padding: dp(10)
    spacing: dp(0)

    canvas.before:
        Color:
            rgba: 0.08, 0.08, 0.08, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [24, 24, 24, 24]

    Widget:
        size_hint_y: None
        height: dp(18)

    FloatLayout:
        size_hint_y: None
        height: dp(160)

        MDCard:
            size_hint: 1, 1
            pos_hint: {"x": 0, "y": 0}
            radius: [8, 8, 8, 8]
            elevation: 0
            padding: 0
            md_bg_color: 0, 0, 0, 1
            line_color: 0, 0, 0, 0

            FitImage:
                source: root.image
                radius: [8, 8, 8, 8]
                size_hint: 1, 1

        MDIconButton:
            id: cart_btn
            icon: "cart-outline"
            theme_icon_color: "Custom"
            icon_color: 1, 1, 1, 1
            pos_hint: {"x": 0.0, "top": 0.96}
            on_release:
                root.add_to_cart()
                self.icon = "cart"

        MDIconButton:
            icon: "heart" if root.is_liked else "heart-outline"
            theme_icon_color: "Custom"
            icon_color: (1, 0, 0, 1) if root.is_liked else (1, 1, 1, 1)
            pos_hint: {"right": 1, "top": 1}
            on_release: root.toggle_like()

        MDLabel:
            text: root.prep_time
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            halign: "right"
            size_hint: None, None
            size: dp(80), dp(24)
            pos_hint: {"right": 0.97, "y": 0.02}

    Widget:
        size_hint_y: None
        height: dp(10)

    BoxLayout:
        orientation: "vertical"
        size_hint_y: None
        height: dp(108)
        spacing: dp(4)

        Label:
            text: root.title
            font_name: "fonts/Inter-Italic-VariableFont_opsz,wght.ttf"
            font_size: "14sp"
            color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(22)
            text_size: self.width, None
            halign: "left"
            valign: "middle"
            shorten: True
            shorten_from: "right"

        Label:
            text: root.desc
            font_name: "fonts/Inter-Italic-VariableFont_opsz,wght.ttf"
            font_size: "12sp"
            color: 0.72, 0.72, 0.72, 1
            size_hint_y: None
            height: dp(58)
            text_size: self.width, None
            halign: "left"
            valign: "top"
            line_height: 1.2

        Widget:

        Label:
            text: root.calories
            font_name: "fonts/Inter-Italic-VariableFont_opsz,wght.ttf"
            font_size: "10sp"
            color: 0.72, 0.72, 0.72, 1
            size_hint_y: None
            height: dp(20)
            text_size: self.width, None
            halign: "right"
            valign: "top"

<DashboardScreen>:
    name: "dashboard"

    FloatLayout:
        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                source: "background_big_ingredients.png"
                pos: self.pos
                size: self.size

        ScrollView:
            do_scroll_x: False
            do_scroll_y: True
            size_hint: 1, 1

            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(20)
                padding: dp(16), dp(8), dp(16), dp(120)

                Label:
                    text: "Popularne"
                    font_name: "fonts/Poppins-Bold.ttf"
                    font_size: "24sp"
                    color: 0.95, 0.95, 0.95, 1
                    size_hint_y: None
                    height: self.texture_size[1]
                    text_size: self.width, None
                    halign: "left"
                    valign: "middle"

                ScrollView:
                    size_hint_y: None
                    height: dp(380)
                    do_scroll_y: False
                    do_scroll_x: True
                    bar_width: 0

                    BoxLayout:
                        id: popular_box
                        orientation: "horizontal"
                        size_hint_x: None
                        width: self.minimum_width
                        size_hint_y: None
                        height: dp(340)
                        spacing: dp(14)
                        padding: dp(2), dp(8)

                Widget:
                    size_hint_y: None
                    height: dp(20)

        BoxLayout:
            id: cart_bar
            orientation: "horizontal"
            size_hint: 0.94, None
            height: dp(150)
            pos_hint: {"center_x": 0.5}
            y: -dp(120)
            opacity: 1 if root.cart_visible else 0
            disabled: not root.cart_visible
            spacing: dp(10)
            padding: dp(10)

            canvas.before:
                Color:
                    rgba: 0.08, 0.08, 0.08, 0.98
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [18, 18, 18, 18]
            line_color: 0, 0, 0, 0

            BoxLayout:
                spacing: dp(10)
                padding: dp(10)

                # 🔥 LEWA CZĘŚĆ (70%) — produkty
                BoxLayout:
                    size_hint_x: 0.7

                    ScrollView:
                        do_scroll_y: False
                        do_scroll_x: True
                        bar_width: 0

                        BoxLayout:
                            id: cart_items_box
                            orientation: "horizontal"
                            size_hint_x: None
                            width: self.minimum_width
                            height: self.minimum_height
                            size_hint_y: 1
                            spacing: dp(10)

                # 🔥 SEPARATOR
                Widget:
                    size_hint_x: None
                    width: dp(1)

                    canvas:
                        Color:
                            rgba: 0.3, 0.3, 0.3, 1
                        Rectangle:
                            pos: self.center_x - dp(0.5), self.y + dp(10)
                            size: dp(1), self.height - dp(20)

                # 🔥 PRAWA CZĘŚĆ (30%) — akcje
                BoxLayout:
                    orientation: "vertical"
                    size_hint_x: 0.3
                    spacing: dp(6)

                    Label:
                        text: root.cart_eta
                        font_name: "fonts/Poppins-Bold.ttf"
                        font_size: "12sp"
                        color: 1, 1, 1, 1
                        halign: "center"
                        valign: "middle"
                        text_size: self.size

                    Label:
                        text: f"PLN {root.cart_total}"
                        font_name: "fonts/Poppins-Bold.ttf"
                        font_size: "12sp"
                        color: 0.8, 0.8, 0.8, 1
                        halign: "center"
                        valign: "middle"
                        text_size: self.size
                        text_color: 1, 1, 1, 0.9

                    Button:
                        text: "DALEJ"
                        font_name: "fonts/Poppins-Bold.ttf"
                        font_size: "14sp"
                        bold: True
                        background_normal: ""
                        background_down: ""
                        background_color: 0.93, 0.50, 0.13, 1
                        color: 1, 1, 1, 1

<DeliveryScreen>:
    name: "delivery"

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(20)

        MDLabel:
            text: "Adres dostawy"
            halign: "center"
            font_style: "Title"

        MDTextField:
            id: street
            hint_text: "Ulica i numer"
            mode: "filled"

        MDTextField:
            id: city
            hint_text: "Miasto"
            mode: "filled"

        MDTextField:
            id: postal
            hint_text: "Kod pocztowy"
            mode: "filled"

        MDTextField:
            id: phone
            hint_text: "Telefon kontaktowy"
            mode: "filled"

        MDButton:
            text: "Zapisz adres"
            on_release: app.save_address()


<RegisterScreen>:
    name: "register"

    MDScreen:
        md_bg_color: 0.98, 0.95, 0.92, 1

        MDBoxLayout:
            orientation: "vertical"
            padding: dp(20)
            spacing: dp(16)

            Widget:
                size_hint_y: 0.08

            MDCard:
                orientation: "vertical"
                size_hint: None, None
                size: dp(320), dp(500)
                pos_hint: {"center_x": 0.5}
                padding: dp(24)
                spacing: dp(16)
                radius: [22, 22, 22, 22]
                elevation: 0
                md_bg_color: 0.93, 0.93, 0.96, 1

                MDLabel:
                    text: "Rejestracja"
                    halign: "center"
                    bold: True
                    font_style: "Headline"
                    size_hint_y: None
                    height: self.texture_size[1]

                MDTextField:
                    id: email
                    mode: "outlined"

                    MDTextFieldHintText:
                        text: "Email"

                    MDTextFieldTrailingIcon:
                        icon: "email-outline"

                MDTextField:
                    id: phone
                    mode: "outlined"

                    MDTextFieldHintText:
                        text: "Telefon"

                    MDTextFieldTrailingIcon:
                        icon: "phone-outline"

                MDTextField:
                    id: password
                    mode: "outlined"
                    password: True

                    MDTextFieldHintText:
                        text: "Hasło"

                    MDTextFieldTrailingIcon:
                        icon: "lock-outline"

                Widget:
                    size_hint_y: None
                    height: dp(4)

                MDButton:
                    style: "filled"
                    pos_hint: {"center_x": 0.5}
                    on_release: app.register()

                    MDButtonText:
                        text: "Załóż konto"

                MDButton:
                    style: "text"
                    pos_hint: {"center_x": 0.5}
                    on_release: app.switch_to_login()

                    MDButtonText:
                        text: "Masz już konto? Zaloguj się"

                Widget:
                    size_hint_y: None
                    height: dp(8)

            Widget:
                size_hint_y: 0.12


<LoginScreen>:
    name: "login"

    MDScreen:
        md_bg_color: 0.98, 0.95, 0.92, 1

        MDBoxLayout:
            orientation: "vertical"
            padding: dp(20)
            spacing: dp(16)

            Widget:
                size_hint_y: 0.12

            MDCard:
                orientation: "vertical"
                size_hint: None, None
                size: dp(320), dp(520)
                pos_hint: {"center_x": 0.5}
                padding: dp(24)
                spacing: dp(16)
                radius: [22, 22, 22, 22]
                elevation: 0
                md_bg_color: 0.93, 0.93, 0.96, 1

                MDLabel:
                    text: "Logowanie"
                    halign: "center"
                    font_style: "Headline"
                    role: "small"
                    bold: True
                    size_hint_y: None
                    height: self.texture_size[1]

                MDTextField:
                    id: email
                    mode: "outlined"

                    MDTextFieldHintText:
                        text: "Email"

                    MDTextFieldTrailingIcon:
                        icon: "email-outline"

                MDTextField:
                    id: password
                    mode: "outlined"
                    password: True

                    MDTextFieldHintText:
                        text: "Hasło"

                    MDTextFieldTrailingIcon:
                        icon: "lock-outline"

                MDButton:
                    style: "filled"
                    pos_hint: {"center_x": 0.5}
                    on_release: app.login()

                    MDButtonText:
                        text: "Zaloguj"

                MDButton:
                    style: "text"
                    pos_hint: {"center_x": 0.5}
                    on_release: app.switch_to_register()

                    MDButtonText:
                        text: "Nie masz konta? Zarejestruj się"

                MDCircularProgressIndicator:
                    id: login_spinner
                    size_hint: None, None
                    size: dp(36), dp(36)
                    pos_hint: {"center_x": 0.5}
                    active: False

                MDButton:
                    style: "outlined"
                    pos_hint: {"center_x": 0.5}
                    on_release: app.google_login()

                    MDButtonText:
                        text: "Zaloguj przez Google"

            Widget:
                size_hint_y: 0.12




<OrderSummaryScreen>:
    name: "summary"

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Podsumowanie"
            left_action_items: [["arrow-left", lambda x: app.go_back()]]

        MDBoxLayout:
            orientation: "vertical"
            padding: dp(10)
            spacing: dp(10)

            MDLabel:
                id: order_type_label
                text: "Typ zamówienia"

            MDLabel:
                id: address_label
                text: "Adres:"

            MDTextField:
                id: notes_field
                hint_text: "Uwagi do zamówienia"

        MDBoxLayout:
            size_hint_y: None
            height: "60dp"
            padding: dp(10)

            MDButton:
                text: "Wyślij zamówienie"
                pos_hint: {"center_x": 0.5}
                on_release:
                    app.submit_order()


<OrdersHistoryScreen>:
    name: "history"

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Ostatnie zamówienia"
            left_action_items: [["arrow-left", lambda x: app.go_back()]]

        ScrollView:
            MDList:
                id: history_list


<AddressScreen>:
    name: "addresses"

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Adresy dostawy"
            left_action_items: [["arrow-left", lambda x: app.go_back()]]

        ScrollView:
            MDList:
                id: addresses_list

        MDFabButton:
            icon: "plus"
            md_bg_color: 1, 0.5, 0, 1
            pos_hint: {"right": 0.95, "y": 0.05}
            on_release: app.show_address_form()

