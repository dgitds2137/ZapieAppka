ScreenManager:
    RegisterScreen:
    LoginScreen:
    DashboardScreen:
    DeliveryScreen:
    PositionScreen:
    CartScreen:
    OrderSummaryScreen:
    OrdersHistoryScreen:
    AddressScreen:


<PositionScreen>:
    name: "position"
    id: position
    pos_id: 0
    position: None

    BoxLayout:
        orientation: "vertical"
        size_hint_y: 1
        size_hint_x: 1
        pos_hint: {"top": 1}

        # --- górny pasek z powrotem i serduszkiem ---
        FloatLayout:
            size_hint_y: None
            height: dp(50)

            MDIconButton:
                icon: "arrow-left"
                pos_hint: {"x": 0, "top": 1}
                on_release: app.go_back()

            MDIconButton:
                id: fav_btn
                icon: "heart-outline"
                pos_hint: {"right": 1, "top": 1}
                on_release: app.toggle_favorite()

        # --- obrazek, tytuł i opis ---
        AsyncImage:
            id: pos_image
            source: ""
            allow_stretch: True
            keep_ratio: True
            size_hint_x: 0.8
            size_hint_y: None
            height: dp(250)
            pos_hint: {"center_x": 0.5}

        MDLabel:
            id: pos_title
            text: ""
            font_style: "Title"
            halign: "center"
            size_hint_y: None
            height: dp(40)

        MDLabel:
            id: pos_desc
            text: ""
            halign: "center"
            theme_text_color: "Secondary"
            size_hint_y: None
            height: dp(80)

        MDButton:
            id: add_to
            text: "Dodaj do koszyka (0)"
            size_hint_x: 0.8
            pos_hint: {"center_x": 0.5}
            on_release: app.add_to_cart(root.position)


<DashboardScreen>:
    name: "dashboard"

    MDScreen:
        md_bg_color: 0, 0, 0, 1

        ScrollView:
            do_scroll_x: False

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                padding: dp(16)
                spacing: dp(20)

                MDLabel:
                    text: "Popularne"
                    bold: True
                    font_size: "28sp"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    size_hint_y: None
                    height: self.texture_size[1]

                MDGridLayout:
                    id: products_grid
                    cols: 2
                    adaptive_height: True
                    spacing: dp(12)

<ProductCard>:
    orientation: "vertical"
    size_hint_y: None
    height: dp(220)
    radius: [18, 18, 18, 18]
    elevation: 0
    padding: dp(8)
    spacing: dp(8)
    md_bg_color: 0.12, 0.12, 0.12, 1

    AsyncImage:
        source: root.image
        size_hint_y: None
        height: dp(120)
        allow_stretch: True
        keep_ratio: False

    MDLabel:
        text: root.title
        bold: True
        theme_text_color: "Custom"
        text_color: 1, 1, 1, 1
        font_size: "18sp"
        size_hint_y: None
        height: self.texture_size[1]

    MDLabel:
        text: root.desc
        theme_text_color: "Custom"
        text_color: 0.75, 0.75, 0.75, 1
        font_size: "13sp"
        text_size: self.width, None
        size_hint_y: None
        height: self.texture_size[1]

<DeliveryScreen>:
    name: "delivery"

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(20)

        MDLabel:
            text: "Adres dostawy"
            halign: "center"
            font_style: "Title"

        MDTextField:
            id: street
            hint_text: "Ulica i numer"
            mode: "filled"

        MDTextField:
            id: city
            hint_text: "Miasto"
            mode: "filled"

        MDTextField:
            id: postal
            hint_text: "Kod pocztowy"
            mode: "filled"

        MDTextField:
            id: phone
            hint_text: "Telefon kontaktowy"
            mode: "filled"

        MDButton:
            text: "Zapisz adres"
            on_release: app.save_address()


<RegisterScreen>:
    name: "register"

    MDScreen:
        md_bg_color: 0.98, 0.95, 0.92, 1

        MDBoxLayout:
            orientation: "vertical"
            padding: dp(20)
            spacing: dp(16)

            Widget:
                size_hint_y: 0.08

            MDCard:
                orientation: "vertical"
                size_hint: None, None
                size: dp(320), dp(500)
                pos_hint: {"center_x": 0.5}
                padding: dp(24)
                spacing: dp(16)
                radius: [22, 22, 22, 22]
                elevation: 0
                md_bg_color: 0.93, 0.93, 0.96, 1

                MDLabel:
                    text: "Rejestracja"
                    halign: "center"
                    bold: True
                    font_style: "Headline"
                    size_hint_y: None
                    height: self.texture_size[1]

                MDTextField:
                    id: email
                    mode: "outlined"

                    MDTextFieldHintText:
                        text: "Email"

                    MDTextFieldTrailingIcon:
                        icon: "email-outline"

                MDTextField:
                    id: phone
                    mode: "outlined"

                    MDTextFieldHintText:
                        text: "Telefon"

                    MDTextFieldTrailingIcon:
                        icon: "phone-outline"

                MDTextField:
                    id: password
                    mode: "outlined"
                    password: True

                    MDTextFieldHintText:
                        text: "Hasło"

                    MDTextFieldTrailingIcon:
                        icon: "lock-outline"

                Widget:
                    size_hint_y: None
                    height: dp(4)

                MDButton:
                    style: "filled"
                    pos_hint: {"center_x": 0.5}
                    on_release: app.register()

                    MDButtonText:
                        text: "Załóż konto"

                MDButton:
                    style: "text"
                    pos_hint: {"center_x": 0.5}
                    on_release: app.switch_to_login()

                    MDButtonText:
                        text: "Masz już konto? Zaloguj się"

                Widget:
                    size_hint_y: None
                    height: dp(8)

            Widget:
                size_hint_y: 0.12


<LoginScreen>:
    name: "login"

    MDScreen:
        md_bg_color: 0.98, 0.95, 0.92, 1

        MDBoxLayout:
            orientation: "vertical"
            padding: dp(20)
            spacing: dp(16)

            Widget:
                size_hint_y: 0.12

            MDCard:
                orientation: "vertical"
                size_hint: None, None
                size: dp(320), dp(520)
                pos_hint: {"center_x": 0.5}
                padding: dp(24)
                spacing: dp(16)
                radius: [22, 22, 22, 22]
                elevation: 0
                md_bg_color: 0.93, 0.93, 0.96, 1

                MDLabel:
                    text: "Logowanie"
                    halign: "center"
                    font_style: "Headline"
                    role: "small"
                    bold: True
                    size_hint_y: None
                    height: self.texture_size[1]

                MDTextField:
                    id: email
                    mode: "outlined"

                    MDTextFieldHintText:
                        text: "Email"

                    MDTextFieldTrailingIcon:
                        icon: "email-outline"

                MDTextField:
                    id: password
                    mode: "outlined"
                    password: True

                    MDTextFieldHintText:
                        text: "Hasło"

                    MDTextFieldTrailingIcon:
                        icon: "lock-outline"

                MDButton:
                    style: "filled"
                    pos_hint: {"center_x": 0.5}
                    on_release: app.login()

                    MDButtonText:
                        text: "Zaloguj"

                MDButton:
                    style: "text"
                    pos_hint: {"center_x": 0.5}
                    on_release: app.switch_to_register()

                    MDButtonText:
                        text: "Nie masz konta? Zarejestruj się"

                MDCircularProgressIndicator:
                    id: login_spinner
                    size_hint: None, None
                    size: dp(36), dp(36)
                    pos_hint: {"center_x": 0.5}
                    active: False

                MDButton:
                    style: "outlined"
                    pos_hint: {"center_x": 0.5}
                    on_release: app.google_login()

                    MDButtonText:
                        text: "Zaloguj przez Google"

            Widget:
                size_hint_y: 0.12



<CartScreen>:
    name: "cart"

    MDBoxLayout:
        orientation: "vertical"
        spacing: dp(10)
        padding: dp(10)

        MDLabel:
            text: "Twój koszyk"
            font_style: "Title"
            halign: "center"
            size_hint_y: None
            height: dp(40)

        ScrollView:
            MDBoxLayout:
                id: cart_box
                orientation: "vertical"
                adaptive_height: True
                spacing: dp(10)

        # --- pole na uwagi ---
        MDTextField:
            id: notes_field
            hint_text: "Uwagi do zamówienia"
            multiline: True
            size_hint_y: None
            height: dp(100)

        # --- metoda dostawy ---
        MDLabel:
            text: "Metoda dostawy"
            font_style: "Body"
            halign: "left"
            size_hint_y: None
            height: dp(30)

        MDBoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(40)
            spacing: dp(10)

            MDCheckbox:
                group: "delivery"
                active: True
                on_active: app.set_delivery("local")

            MDLabel:
                text: "Na miejscu"
                halign: "left"

        MDBoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(40)
            spacing: dp(10)

            MDCheckbox:
                group: "delivery"
                on_active: app.set_delivery("delivery")

            MDLabel:
                text: "Dostawa"
                halign: "left"

        # --- przycisk potwierdzenia ---
        MDButton:
            text: "Potwierdź zamówienie"
            size_hint_x: 0.8
            pos_hint: {"center_x": 0.5}
            on_release: app.confirm_order()


<OrderSummaryScreen>:
    name: "summary"

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Podsumowanie"
            left_action_items: [["arrow-left", lambda x: app.go_back()]]

        MDBoxLayout:
            orientation: "vertical"
            padding: dp(10)
            spacing: dp(10)

            MDLabel:
                id: order_type_label
                text: "Typ zamówienia"

            MDLabel:
                id: address_label
                text: "Adres:"

            MDTextField:
                id: notes_field
                hint_text: "Uwagi do zamówienia"

        MDBoxLayout:
            size_hint_y: None
            height: "60dp"
            padding: dp(10)

            MDButton:
                text: "Wyślij zamówienie"
                pos_hint: {"center_x": 0.5}
                on_release:
                    app.submit_order()


<OrdersHistoryScreen>:
    name: "history"

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Ostatnie zamówienia"
            left_action_items: [["arrow-left", lambda x: app.go_back()]]

        ScrollView:
            MDList:
                id: history_list


<AddressScreen>:
    name: "addresses"

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Adresy dostawy"
            left_action_items: [["arrow-left", lambda x: app.go_back()]]

        ScrollView:
            MDList:
                id: addresses_list

        MDFabButton:
            icon: "plus"
            md_bg_color: 1, 0.5, 0, 1
            pos_hint: {"right": 0.95, "y": 0.05}
            on_release: app.show_address_form()

